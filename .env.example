# Consularis – copy this file to backend/.env and set your values
# The backend loads backend/.env at startup.

# ── AWS Bedrock (required for chat and reports) ──
# IAM user/role needs bedrock:InvokeModel permission.
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# Default planner model (used when user has not picked one).
NOVA_MODEL_ID=us.amazon.nova-pro-v1:0
# Optional: cheaper model for retries/summaries. If unset, NOVA_MODEL_ID is used.
# NOVA_CHEAP_MODEL_ID=us.amazon.nova-2-lite-v1:0

# Optional: full list of models for the chat model picker. If unset, a built-in US list is used.
# Single line, JSON array. Each item: id, label, family (nova|claude|llama|mistral), tier (pro|lite), description.
# Example (US): BEDROCK_MODELS_JSON=[{"id":"us.amazon.nova-pro-v1:0","label":"Nova Pro","family":"nova","tier":"pro","description":"Default"},{"id":"us.amazon.nova-lite-v1:0","label":"Nova Lite","family":"nova","tier":"lite","description":"Faster"}]
# Example (EU): BEDROCK_MODELS_JSON=[{"id":"eu.amazon.nova-pro-v1:0","label":"Nova Pro (EU)","family":"nova","tier":"pro","description":"Default"},{"id":"eu.amazon.nova-2-lite-v1:0","label":"Nova 2 Lite (EU)","family":"nova","tier":"lite","description":"Faster"}]

# Optional: template used to seed baseline at startup (default: pharmacy). One subfolder per type under backend/data/.
# BASELINE_TEMPLATE=pharmacy

# Optional: CORS, logging, timeouts (see backend/config.py defaults)
# ALLOWED_CORS_ORIGINS=http://localhost:5173,http://localhost:5174
# LOG_LEVEL=INFO
