# Paste these lines into your .env to define all models from env.
# Default planner model (must be one of the IDs listed in BEDROCK_MODELS_JSON).
NOVA_MODEL_ID=eu.amazon.nova-pro-v1:0
NOVA_CHEAP_MODEL_ID=eu.amazon.nova-2-lite-v1:0

# Full model list for the chat picker (single line JSON). Change IDs/labels to match your region.
BEDROCK_MODELS_JSON=[{"id":"eu.amazon.nova-pro-v1:0","label":"Nova Pro (EU)","family":"nova","tier":"pro","description":"Default planner model"},{"id":"eu.amazon.nova-2-lite-v1:0","label":"Nova 2 Lite (EU)","family":"nova","tier":"lite","description":"Faster, cheaper"}]
