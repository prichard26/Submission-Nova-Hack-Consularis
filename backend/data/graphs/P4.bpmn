<ns0:definitions xmlns:ns0="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:ns1="http://consularis.example/bpmn" xmlns:ns2="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:ns3="http://www.omg.org/spec/DD/20100524/DC" xmlns:ns4="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <ns0:process id="Process_P4" name="Distribution" isExecutable="false">
    <ns0:laneSet id="LaneSet_1">
      <ns0:lane id="P4" name="Distribution">
        <ns0:flowNodeRef>Start_P4</ns0:flowNodeRef>
        <ns0:flowNodeRef>P4.1</ns0:flowNodeRef>
        <ns0:flowNodeRef>P4.2</ns0:flowNodeRef>
        <ns0:flowNodeRef>P4.3</ns0:flowNodeRef>
        <ns0:flowNodeRef>End_P4</ns0:flowNodeRef>
      </ns0:lane>
    </ns0:laneSet>
    <ns0:startEvent id="Start_P4" name="Start" />
    <ns0:endEvent id="End_P4" name="End" />
    <ns0:task id="P4.1" name="Prepare Distribution">
      <ns0:extensionElements>
        <ns1:actor>Pharmacy Technician</ns1:actor>
        <ns1:durationMin>20–45 min per round</ns1:durationMin>
        <ns1:description>Pick medications for ward/unit orders or patient-specific prescriptions. Build medication carts or fill ADC cassettes.</ns1:description>
        <ns1:inputs>["Ward orders", "Patient prescriptions", "Stock picks"]</ns1:inputs>
        <ns1:outputs>["Prepared medication cart / ADC cassettes"]</ns1:outputs>
        <ns1:risks>["Pick error", "Wrong patient allocation", "Incomplete cart"]</ns1:risks>
        <ns1:automationPotential>high</ns1:automationPotential>
        <ns1:automationNotes>Pharmacy robots, pick-to-light, automated cart fill</ns1:automationNotes>
        <ns1:currentState>manual</ns1:currentState>
        <ns1:frequency>30/day</ns1:frequency>
        <ns1:annualVolume>10950</ns1:annualVolume>
        <ns1:errorRatePercent>3.0</ns1:errorRatePercent>
        <ns1:costPerExecution>12.00 EUR</ns1:costPerExecution>
        <ns1:currentSystems>["Paper pick lists", "ADC"]</ns1:currentSystems>
        <ns1:dataFormat>paper</ns1:dataFormat>
        <ns1:externalDependencies>[]</ns1:externalDependencies>
        <ns1:regulatoryConstraints>["Patient safety standards"]</ns1:regulatoryConstraints>
        <ns1:slaTarget>&lt; 45 min per round</ns1:slaTarget>
        <ns1:painPoints>["Pick errors", "Incomplete carts", "Manual double-checking"]</ns1:painPoints>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P4.2" name="Transport to Care Unit">
      <ns0:extensionElements>
        <ns1:actor>Porter / Pneumatic tube / AGV</ns1:actor>
        <ns1:durationMin>10–30 min</ns1:durationMin>
        <ns1:description>Transport prepared medications from pharmacy to ward/unit. Methods: manual delivery, pneumatic tube systems, or automated guided vehicles.</ns1:description>
        <ns1:inputs>["Prepared cart / packages"]</ns1:inputs>
        <ns1:outputs>["Medications at care unit"]</ns1:outputs>
        <ns1:risks>["Delay", "Damage in transit", "Temperature excursion for cold chain"]</ns1:risks>
        <ns1:automationPotential>medium</ns1:automationPotential>
        <ns1:automationNotes>AGVs, pneumatic tubes, delivery tracking systems</ns1:automationNotes>
        <ns1:currentState>semi_automated</ns1:currentState>
        <ns1:frequency>20/day</ns1:frequency>
        <ns1:annualVolume>7300</ns1:annualVolume>
        <ns1:errorRatePercent>1.0</ns1:errorRatePercent>
        <ns1:costPerExecution>8.00 EUR</ns1:costPerExecution>
        <ns1:currentSystems>["Pneumatic tube", "Porter service"]</ns1:currentSystems>
        <ns1:dataFormat>digital_structured</ns1:dataFormat>
        <ns1:externalDependencies>["Transport logistics"]</ns1:externalDependencies>
        <ns1:regulatoryConstraints>["Cold chain transport", "Controlled substance chain of custody"]</ns1:regulatoryConstraints>
        <ns1:slaTarget>&lt; 30 min</ns1:slaTarget>
        <ns1:painPoints>["Delivery delays", "Cold chain breaks"]</ns1:painPoints>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P4.3" name="Stock Care Unit">
      <ns0:extensionElements>
        <ns1:actor>Nurse / Pharmacy Technician</ns1:actor>
        <ns1:durationMin>15–20 min</ns1:durationMin>
        <ns1:description>Receive medications at ward, verify against order, and load into ward storage or ADC.</ns1:description>
        <ns1:inputs>["Medications at care unit", "Ward order"]</ns1:inputs>
        <ns1:outputs>["Ward stock ready for administration"]</ns1:outputs>
        <ns1:risks>["Wrong ward", "Receiving error", "ADC load error"]</ns1:risks>
        <ns1:automationPotential>medium</ns1:automationPotential>
        <ns1:automationNotes>ADC with barcode verification, nurse confirmation scan</ns1:automationNotes>
        <ns1:currentState>semi_automated</ns1:currentState>
        <ns1:frequency>20/day</ns1:frequency>
        <ns1:annualVolume>7300</ns1:annualVolume>
        <ns1:errorRatePercent>2.5</ns1:errorRatePercent>
        <ns1:costPerExecution>7.00 EUR</ns1:costPerExecution>
        <ns1:currentSystems>["ADC", "Barcode scanner"]</ns1:currentSystems>
        <ns1:dataFormat>digital_structured</ns1:dataFormat>
        <ns1:externalDependencies>[]</ns1:externalDependencies>
        <ns1:regulatoryConstraints>["Ward stock management policies"]</ns1:regulatoryConstraints>
        <ns1:slaTarget>&lt; 20 min</ns1:slaTarget>
        <ns1:painPoints>["ADC load errors", "Wrong ward deliveries"]</ns1:painPoints>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:sequenceFlow id="flow_Start_P4_P4.1" sourceRef="Start_P4" targetRef="P4.1" name="Start" />
    <ns0:sequenceFlow id="flow_P4.3_End_P4" sourceRef="P4.3" targetRef="End_P4" name="Complete" />
    <ns0:sequenceFlow id="flow_P4.1_P4.2_11" sourceRef="P4.1" targetRef="P4.2" name="Cart prepared" />
    <ns0:sequenceFlow id="flow_P4.2_P4.3_12" sourceRef="P4.2" targetRef="P4.3" name="Delivered to unit" />
  </ns0:process>
  <ns2:BPMNDiagram id="BPMNDiagram_1">
    <ns2:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_P4">
      <ns2:BPMNShape id="BPMNShape_P4" bpmnElement="P4">
        <ns3:Bounds x="0" y="0" width="1708" height="200" />
      </ns2:BPMNShape>
      <ns2:BPMNShape id="BPMNShape_Start_P4" bpmnElement="Start_P4">
        <ns3:Bounds x="280" y="78" width="44" height="44" />
      </ns2:BPMNShape>
      <ns2:BPMNShape id="BPMNShape_P4.1" bpmnElement="P4.1">
        <ns3:Bounds x="464" y="44" width="220" height="112" />
      </ns2:BPMNShape>
      <ns2:BPMNShape id="BPMNShape_P4.2" bpmnElement="P4.2">
        <ns3:Bounds x="824" y="44" width="220" height="112" />
      </ns2:BPMNShape>
      <ns2:BPMNShape id="BPMNShape_P4.3" bpmnElement="P4.3">
        <ns3:Bounds x="1184" y="44" width="220" height="112" />
      </ns2:BPMNShape>
      <ns2:BPMNShape id="BPMNShape_End_P4" bpmnElement="End_P4">
        <ns3:Bounds x="1544" y="78" width="44" height="44" />
      </ns2:BPMNShape>
      <ns2:BPMNEdge id="BPMNEdge_flow_Start_P4_P4.1" bpmnElement="flow_Start_P4_P4.1">
        <ns4:waypoint x="324" y="100" />
        <ns4:waypoint x="464" y="100" />
      </ns2:BPMNEdge>
      <ns2:BPMNEdge id="BPMNEdge_flow_P4.3_End_P4" bpmnElement="flow_P4.3_End_P4">
        <ns4:waypoint x="1404" y="100" />
        <ns4:waypoint x="1544" y="100" />
      </ns2:BPMNEdge>
      <ns2:BPMNEdge id="BPMNEdge_flow_P4.1_P4.2_11" bpmnElement="flow_P4.1_P4.2_11">
        <ns4:waypoint x="684" y="100" />
        <ns4:waypoint x="824" y="100" />
      </ns2:BPMNEdge>
      <ns2:BPMNEdge id="BPMNEdge_flow_P4.2_P4.3_12" bpmnElement="flow_P4.2_P4.3_12">
        <ns4:waypoint x="1044" y="100" />
        <ns4:waypoint x="1184" y="100" />
      </ns2:BPMNEdge>
    </ns2:BPMNPlane>
  </ns2:BPMNDiagram>
</ns0:definitions>