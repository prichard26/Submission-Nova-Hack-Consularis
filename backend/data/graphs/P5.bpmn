<ns0:definitions xmlns:ns0="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:ns1="http://consularis.example/bpmn" xmlns:ns3="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:ns4="http://www.omg.org/spec/DD/20100524/DC" xmlns:ns5="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:consularis="http://consularis.example/bpmn" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI">
  <ns0:process id="Process_P5" name="Dispensing and Preparation" isExecutable="false">
    <ns0:laneSet id="LaneSet_1">
      <ns0:lane id="P5" name="Dispensing and Preparation">
        <ns0:flowNodeRef>Start_P5</ns0:flowNodeRef>
        <ns0:flowNodeRef>P5.1</ns0:flowNodeRef>
        <ns0:flowNodeRef>P5.2</ns0:flowNodeRef>
        <ns0:flowNodeRef>G5</ns0:flowNodeRef>
        <ns0:flowNodeRef>P5.3</ns0:flowNodeRef>
        <ns0:flowNodeRef>End_P5</ns0:flowNodeRef>
      </ns0:lane>
    </ns0:laneSet>
    <ns0:startEvent id="Start_P5" name="Start" />
    <ns0:endEvent id="End_P5" name="End" />
    <ns0:exclusiveGateway id="G5" name="Outpatient or Inpatient?" />
    <ns0:task id="P5.1" name="Compound / Prepare">
      <ns0:extensionElements>
        <ns1:actor>Pharmacist / Pharmacy Technician</ns1:actor>
        <ns1:durationMin>5–60 min (varies by complexity)</ns1:durationMin>
        <ns1:description>For non-standard preparations: compound medication (e.g. IV admixtures, pediatric formulations, sterile compounds). For standard items: count/pour and label.</ns1:description>
        <ns1:inputs>["Approved prescription", "Raw materials or stock"]</ns1:inputs>
        <ns1:outputs>["Prepared medication with label"]</ns1:outputs>
        <ns1:risks>["Compounding error", "Contamination", "Wrong concentration"]</ns1:risks>
        <ns1:automationPotential>medium</ns1:automationPotential>
        <ns1:automationNotes>IV workflow management, gravimetric verification, compounding robots</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P5.2" name="Final Verification">
      <ns0:extensionElements>
        <ns1:actor>Pharmacist</ns1:actor>
        <ns1:durationMin>3–5 min</ns1:durationMin>
        <ns1:description>Independent check of dispensed medication against prescription: right drug, right dose, right form, right label, right patient.</ns1:description>
        <ns1:inputs>["Prepared medication", "Original prescription"]</ns1:inputs>
        <ns1:outputs>["Verified medication ready for patient"]</ns1:outputs>
        <ns1:risks>["Verification shortcut under pressure", "Look-alike/sound-alike error"]</ns1:risks>
        <ns1:automationPotential>high</ns1:automationPotential>
        <ns1:automationNotes>Barcode verification, image recognition, automated dispensing check</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P5.3" name="Patient Counseling">
      <ns0:extensionElements>
        <ns1:actor>Pharmacist</ns1:actor>
        <ns1:durationMin>3–10 min</ns1:durationMin>
        <ns1:description>Explain medication use, dosage, side effects, interactions, and storage instructions to patient or caregiver.</ns1:description>
        <ns1:inputs>["Verified medication", "Patient profile"]</ns1:inputs>
        <ns1:outputs>["Informed patient", "Counseling record"]</ns1:outputs>
        <ns1:risks>["Missed counseling", "Patient misunderstanding", "Language barrier"]</ns1:risks>
        <ns1:automationPotential>low</ns1:automationPotential>
        <ns1:automationNotes>Printed/digital information sheets, automated reminders for new medications</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:sequenceFlow id="flow_Start_P5_P5.1" sourceRef="Start_P5" targetRef="P5.1" name="Start" />
    <ns0:sequenceFlow id="flow_P5.3_End_P5" sourceRef="P5.3" targetRef="End_P5" name="Complete" />
    <ns0:sequenceFlow id="flow_P5.1_P5.2_13" sourceRef="P5.1" targetRef="P5.2" name="Preparation done" />
    <ns0:sequenceFlow id="flow_P5.2_G5" sourceRef="P5.2" targetRef="G5" name="P5.2 → G5" />
    <ns0:sequenceFlow id="flow_G5_P5.3" sourceRef="G5" targetRef="P5.3" name="Outpatient">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">Outpatient</ns0:conditionExpression>
    </ns0:sequenceFlow>
  </ns0:process>
  <ns3:BPMNDiagram id="BPMNDiagram_1">
    <ns3:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_P5">
      <ns3:BPMNShape id="BPMNShape_P5" bpmnElement="P5">
        <ns4:Bounds x="0" y="0" width="1904" height="200" />
      </ns3:BPMNShape>
      <ns3:BPMNShape id="BPMNShape_Start_P5" bpmnElement="Start_P5">
        <ns4:Bounds x="280" y="78" width="44" height="44" />
      </ns3:BPMNShape>
      <ns3:BPMNShape id="BPMNShape_P5.1" bpmnElement="P5.1">
        <ns4:Bounds x="464" y="44" width="220" height="112" />
      </ns3:BPMNShape>
      <ns3:BPMNShape id="BPMNShape_P5.2" bpmnElement="P5.2">
        <ns4:Bounds x="824" y="44" width="220" height="112" />
      </ns3:BPMNShape>
      <ns3:BPMNShape id="BPMNShape_G5" bpmnElement="G5">
        <ns4:Bounds x="1184" y="72" width="56" height="56" />
      </ns3:BPMNShape>
      <ns3:BPMNShape id="BPMNShape_P5.3" bpmnElement="P5.3">
        <ns4:Bounds x="1380" y="44" width="220" height="112" />
      </ns3:BPMNShape>
      <ns3:BPMNShape id="BPMNShape_End_P5" bpmnElement="End_P5">
        <ns4:Bounds x="1740" y="78" width="44" height="44" />
      </ns3:BPMNShape>
      <ns3:BPMNEdge id="BPMNEdge_flow_Start_P5_P5.1" bpmnElement="flow_Start_P5_P5.1">
        <ns5:waypoint x="324" y="100" />
        <ns5:waypoint x="464" y="100" />
      </ns3:BPMNEdge>
      <ns3:BPMNEdge id="BPMNEdge_flow_P5.3_End_P5" bpmnElement="flow_P5.3_End_P5">
        <ns5:waypoint x="1600" y="100" />
        <ns5:waypoint x="1740" y="100" />
      </ns3:BPMNEdge>
      <ns3:BPMNEdge id="BPMNEdge_flow_P5.1_P5.2_13" bpmnElement="flow_P5.1_P5.2_13">
        <ns5:waypoint x="684" y="100" />
        <ns5:waypoint x="824" y="100" />
      </ns3:BPMNEdge>
      <ns3:BPMNEdge id="BPMNEdge_flow_P5.2_G5" bpmnElement="flow_P5.2_G5">
        <ns5:waypoint x="1044" y="100" />
        <ns5:waypoint x="1184" y="100" />
      </ns3:BPMNEdge>
      <ns3:BPMNEdge id="BPMNEdge_flow_G5_P5.3" bpmnElement="flow_G5_P5.3">
        <ns5:waypoint x="1240" y="100" />
        <ns5:waypoint x="1380" y="100" />
      </ns3:BPMNEdge>
    </ns3:BPMNPlane>
  </ns3:BPMNDiagram>
</ns0:definitions>