<ns0:definitions xmlns:ns0="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:ns1="http://consularis.example/bpmn" xmlns:ns3="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:ns4="http://www.omg.org/spec/DD/20100524/DC" xmlns:ns5="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:consularis="http://consularis.example/bpmn" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI">
  <ns0:process id="Process_P2" name="Selection, Acquisition, and Reception" isExecutable="false">
    <ns0:laneSet id="LaneSet_1">
      <ns0:lane id="P2" name="Selection, Acquisition, and Reception">
        <ns0:flowNodeRef>Start_P2</ns0:flowNodeRef>
        <ns0:flowNodeRef>P2.1</ns0:flowNodeRef>
        <ns0:flowNodeRef>G2</ns0:flowNodeRef>
        <ns0:flowNodeRef>P2.2</ns0:flowNodeRef>
        <ns0:flowNodeRef>P2.3</ns0:flowNodeRef>
        <ns0:flowNodeRef>P2.4</ns0:flowNodeRef>
        <ns0:flowNodeRef>End_P2</ns0:flowNodeRef>
      </ns0:lane>
    </ns0:laneSet>
    <ns0:startEvent id="Start_P2" name="Start" />
    <ns0:endEvent id="End_P2" name="End" />
    <ns0:exclusiveGateway id="G2" name="In stock?" />
    <ns0:task id="P2.1" name="Select Medication">
      <ns0:extensionElements>
        <ns1:actor>Pharmacist</ns1:actor>
        <ns1:durationMin>15 min</ns1:durationMin>
        <ns1:description>Choose the appropriate medication from available stock or formulary, considering therapeutic equivalence, cost, and availability.</ns1:description>
        <ns1:inputs>["Approved prescription", "Inventory data", "Formulary"]</ns1:inputs>
        <ns1:outputs>["Selected medication item"]</ns1:outputs>
        <ns1:risks>["Stock-out", "Wrong therapeutic equivalent"]</ns1:risks>
        <ns1:automationPotential>medium</ns1:automationPotential>
        <ns1:automationNotes>ERP-linked formulary lookup, auto-substitution suggestions</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P2.2" name="Acquire Medication">
      <ns0:extensionElements>
        <ns1:actor>Procurement / Pharmacist</ns1:actor>
        <ns1:durationMin>1 hour – 3 days</ns1:durationMin>
        <ns1:description>Place purchase orders with suppliers for medications not in stock. Includes vendor selection, PO creation, and order tracking.</ns1:description>
        <ns1:inputs>["Reorder point trigger", "Supplier catalog", "Budget approval"]</ns1:inputs>
        <ns1:outputs>["Purchase order"]</ns1:outputs>
        <ns1:risks>["Supply shortage", "Price volatility", "Supplier reliability"]</ns1:risks>
        <ns1:automationPotential>high</ns1:automationPotential>
        <ns1:automationNotes>Automated reorder points, EDI with suppliers, demand forecasting</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P2.3" name="Receive Shipment">
      <ns0:extensionElements>
        <ns1:actor>Pharmacy Technician</ns1:actor>
        <ns1:durationMin>30 min</ns1:durationMin>
        <ns1:description>Receive delivery from supplier, verify package integrity, check delivery documentation against purchase order.</ns1:description>
        <ns1:inputs>["Delivery", "Purchase order", "Packing slip"]</ns1:inputs>
        <ns1:outputs>["Received goods"]</ns1:outputs>
        <ns1:risks>["Damaged goods", "Wrong delivery", "Temperature excursion"]</ns1:risks>
        <ns1:automationPotential>medium</ns1:automationPotential>
        <ns1:automationNotes>Barcode/RFID scanning at receiving dock</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P2.4" name="Verify Shipment">
      <ns0:extensionElements>
        <ns1:actor>Pharmacist / QA</ns1:actor>
        <ns1:durationMin>20 min</ns1:durationMin>
        <ns1:description>Quality assurance check: verify quantities, lot numbers, expiry dates, and product condition against order details.</ns1:description>
        <ns1:inputs>["Received goods", "Purchase order"]</ns1:inputs>
        <ns1:outputs>["Verified inventory ready for storage"]</ns1:outputs>
        <ns1:risks>["Expired products accepted", "Counterfeit drugs", "Quantity mismatch"]</ns1:risks>
        <ns1:automationPotential>high</ns1:automationPotential>
        <ns1:automationNotes>Automated lot/expiry scanning, serialization verification</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:sequenceFlow id="flow_Start_P2_P2.1" sourceRef="Start_P2" targetRef="P2.1" name="Start" />
    <ns0:sequenceFlow id="flow_P2.4_End_P2" sourceRef="P2.4" targetRef="End_P2" name="Complete" />
    <ns0:sequenceFlow id="flow_P2.1_G2" sourceRef="P2.1" targetRef="G2" name="P2.1 → G2" />
    <ns0:sequenceFlow id="flow_G2_P2.2" sourceRef="G2" targetRef="P2.2" name="Out of stock">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">Out of stock</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="flow_P2.2_P2.3_5" sourceRef="P2.2" targetRef="P2.3" name="Shipment arrives" />
    <ns0:sequenceFlow id="flow_P2.3_P2.4_6" sourceRef="P2.3" targetRef="P2.4" name="Shipment received" />
  </ns0:process>
  <ns3:BPMNDiagram id="BPMNDiagram_1">
    <ns3:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_P2">
      <ns3:BPMNShape id="BPMNShape_P2" bpmnElement="P2">
        <ns4:Bounds x="0" y="0" width="2264" height="200" />
      </ns3:BPMNShape>
      <ns3:BPMNShape id="BPMNShape_Start_P2" bpmnElement="Start_P2">
        <ns4:Bounds x="280" y="78" width="44" height="44" />
      </ns3:BPMNShape>
      <ns3:BPMNShape id="BPMNShape_P2.1" bpmnElement="P2.1">
        <ns4:Bounds x="464" y="44" width="220" height="112" />
      </ns3:BPMNShape>
      <ns3:BPMNShape id="BPMNShape_G2" bpmnElement="G2">
        <ns4:Bounds x="824" y="72" width="56" height="56" />
      </ns3:BPMNShape>
      <ns3:BPMNShape id="BPMNShape_P2.2" bpmnElement="P2.2">
        <ns4:Bounds x="1020" y="44" width="220" height="112" />
      </ns3:BPMNShape>
      <ns3:BPMNShape id="BPMNShape_P2.3" bpmnElement="P2.3">
        <ns4:Bounds x="1380" y="44" width="220" height="112" />
      </ns3:BPMNShape>
      <ns3:BPMNShape id="BPMNShape_P2.4" bpmnElement="P2.4">
        <ns4:Bounds x="1740" y="44" width="220" height="112" />
      </ns3:BPMNShape>
      <ns3:BPMNShape id="BPMNShape_End_P2" bpmnElement="End_P2">
        <ns4:Bounds x="2100" y="78" width="44" height="44" />
      </ns3:BPMNShape>
      <ns3:BPMNEdge id="BPMNEdge_flow_Start_P2_P2.1" bpmnElement="flow_Start_P2_P2.1">
        <ns5:waypoint x="324" y="100" />
        <ns5:waypoint x="464" y="100" />
      </ns3:BPMNEdge>
      <ns3:BPMNEdge id="BPMNEdge_flow_P2.4_End_P2" bpmnElement="flow_P2.4_End_P2">
        <ns5:waypoint x="1960" y="100" />
        <ns5:waypoint x="2100" y="100" />
      </ns3:BPMNEdge>
      <ns3:BPMNEdge id="BPMNEdge_flow_P2.1_G2" bpmnElement="flow_P2.1_G2">
        <ns5:waypoint x="684" y="100" />
        <ns5:waypoint x="824" y="100" />
      </ns3:BPMNEdge>
      <ns3:BPMNEdge id="BPMNEdge_flow_G2_P2.2" bpmnElement="flow_G2_P2.2">
        <ns5:waypoint x="880" y="100" />
        <ns5:waypoint x="1020" y="100" />
      </ns3:BPMNEdge>
      <ns3:BPMNEdge id="BPMNEdge_flow_P2.2_P2.3_5" bpmnElement="flow_P2.2_P2.3_5">
        <ns5:waypoint x="1240" y="100" />
        <ns5:waypoint x="1380" y="100" />
      </ns3:BPMNEdge>
      <ns3:BPMNEdge id="BPMNEdge_flow_P2.3_P2.4_6" bpmnElement="flow_P2.3_P2.4_6">
        <ns5:waypoint x="1600" y="100" />
        <ns5:waypoint x="1740" y="100" />
      </ns3:BPMNEdge>
    </ns3:BPMNPlane>
  </ns3:BPMNDiagram>
</ns0:definitions>