<ns0:definitions xmlns:ns0="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:ns1="http://consularis.example/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:consularis="http://consularis.example/bpmn" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <ns0:process id="Process_Pharmacy" name="Pharmacy medication circuit" isExecutable="false">
    <ns0:laneSet id="LaneSet_1">
      <ns0:lane id="P1" name="Prescription">
        <ns0:flowNodeRef>Start_1</ns0:flowNodeRef>
        <ns0:flowNodeRef>P1.1</ns0:flowNodeRef>
        <ns0:flowNodeRef>P1.2</ns0:flowNodeRef>
        <ns0:flowNodeRef>P1.3</ns0:flowNodeRef>
      </ns0:lane>
      <ns0:lane id="P2" name="Selection, Acquisition, and Reception">
        <ns0:flowNodeRef>P2.1</ns0:flowNodeRef>
        <ns0:flowNodeRef>G2</ns0:flowNodeRef>
        <ns0:flowNodeRef>P2.2</ns0:flowNodeRef>
        <ns0:flowNodeRef>P2.3</ns0:flowNodeRef>
        <ns0:flowNodeRef>P2.4</ns0:flowNodeRef>
      </ns0:lane>
      <ns0:lane id="P3" name="Storage and Storage Management">
        <ns0:flowNodeRef>P3.1</ns0:flowNodeRef>
        <ns0:flowNodeRef>P3.2</ns0:flowNodeRef>
        <ns0:flowNodeRef>P3.3</ns0:flowNodeRef>
        <ns0:flowNodeRef>G3</ns0:flowNodeRef>
      </ns0:lane>
      <ns0:lane id="P4" name="Distribution">
        <ns0:flowNodeRef>P4.1</ns0:flowNodeRef>
        <ns0:flowNodeRef>P4.2</ns0:flowNodeRef>
        <ns0:flowNodeRef>P4.3</ns0:flowNodeRef>
      </ns0:lane>
      <ns0:lane id="P5" name="Dispensing and Preparation">
        <ns0:flowNodeRef>P5.1</ns0:flowNodeRef>
        <ns0:flowNodeRef>P5.2</ns0:flowNodeRef>
        <ns0:flowNodeRef>G5</ns0:flowNodeRef>
        <ns0:flowNodeRef>P5.3</ns0:flowNodeRef>
      </ns0:lane>
      <ns0:lane id="P6" name="Administration">
        <ns0:flowNodeRef>P6.1</ns0:flowNodeRef>
        <ns0:flowNodeRef>P6.2</ns0:flowNodeRef>
        <ns0:flowNodeRef>P6.3</ns0:flowNodeRef>
      </ns0:lane>
      <ns0:lane id="P7" name="Monitoring and Waste Management">
        <ns0:flowNodeRef>P7.1</ns0:flowNodeRef>
        <ns0:flowNodeRef>P7.2</ns0:flowNodeRef>
        <ns0:flowNodeRef>P7.3</ns0:flowNodeRef>
        <ns0:flowNodeRef>End_1</ns0:flowNodeRef>
      </ns0:lane>
    </ns0:laneSet>
    <ns0:startEvent id="Start_1" name="Start" />
    <ns0:endEvent id="End_1" name="End" />
    <ns0:exclusiveGateway id="G2" name="In stock?" />
    <ns0:exclusiveGateway id="G3" name="Inventory decision" />
    <ns0:exclusiveGateway id="G5" name="Outpatient or Inpatient?" />
    <ns0:task id="P1.1" name="Prescribe Medication">
      <ns0:extensionElements>
        <ns1:actor>Physician</ns1:actor>
        <ns1:durationMin>5–10 min</ns1:durationMin>
        <ns1:description>Doctor writes or enters a prescription with drug name, dosage form, strength, frequency, and duration.</ns1:description>
        <ns1:inputs>["Patient diagnosis", "Medical history", "Drug formulary"]</ns1:inputs>
        <ns1:outputs>["Prescription order"]</ns1:outputs>
        <ns1:risks>["Prescribing error", "Drug interaction", "Wrong dosage"]</ns1:risks>
        <ns1:automationPotential>high</ns1:automationPotential>
        <ns1:automationNotes>E-prescribing systems, clinical decision support (CDS), drug interaction alerts</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P1.2" name="Verify Prescription">
      <ns0:extensionElements>
        <ns1:actor>Pharmacist</ns1:actor>
        <ns1:durationMin>5–10 min</ns1:durationMin>
        <ns1:description>Review prescription for compliance with medical standards, hospital policies, drug interactions, and patient allergies.</ns1:description>
        <ns1:inputs>["Prescription order", "Patient allergy record", "Formulary"]</ns1:inputs>
        <ns1:outputs>["Verified prescription"]</ns1:outputs>
        <ns1:risks>["Missed interaction", "Allergy oversight", "Illegible handwriting"]</ns1:risks>
        <ns1:automationPotential>high</ns1:automationPotential>
        <ns1:automationNotes>Automated drug-drug / drug-allergy checks, barcode verification</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P1.3" name="Approve Prescription">
      <ns0:extensionElements>
        <ns1:actor>Pharmacist</ns1:actor>
        <ns1:durationMin>3–5 min</ns1:durationMin>
        <ns1:description>Authorize prescription for dispensation after confirming safety, appropriateness, and formulary compliance.</ns1:description>
        <ns1:inputs>["Verified prescription"]</ns1:inputs>
        <ns1:outputs>["Approved prescription"]</ns1:outputs>
        <ns1:risks>["Delay in approval", "Unauthorized override"]</ns1:risks>
        <ns1:automationPotential>medium</ns1:automationPotential>
        <ns1:automationNotes>Auto-approval for standard formulary items with no flags</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P2.1" name="Select Medication">
      <ns0:extensionElements>
        <ns1:actor>Pharmacist</ns1:actor>
        <ns1:durationMin>15 min</ns1:durationMin>
        <ns1:description>Choose the appropriate medication from available stock or formulary, considering therapeutic equivalence, cost, and availability.</ns1:description>
        <ns1:inputs>["Approved prescription", "Inventory data", "Formulary"]</ns1:inputs>
        <ns1:outputs>["Selected medication item"]</ns1:outputs>
        <ns1:risks>["Stock-out", "Wrong therapeutic equivalent"]</ns1:risks>
        <ns1:automationPotential>medium</ns1:automationPotential>
        <ns1:automationNotes>ERP-linked formulary lookup, auto-substitution suggestions</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P2.2" name="Acquire Medication">
      <ns0:extensionElements>
        <ns1:actor>Procurement / Pharmacist</ns1:actor>
        <ns1:durationMin>1 hour – 3 days</ns1:durationMin>
        <ns1:description>Place purchase orders with suppliers for medications not in stock. Includes vendor selection, PO creation, and order tracking.</ns1:description>
        <ns1:inputs>["Reorder point trigger", "Supplier catalog", "Budget approval"]</ns1:inputs>
        <ns1:outputs>["Purchase order"]</ns1:outputs>
        <ns1:risks>["Supply shortage", "Price volatility", "Supplier reliability"]</ns1:risks>
        <ns1:automationPotential>high</ns1:automationPotential>
        <ns1:automationNotes>Automated reorder points, EDI with suppliers, demand forecasting</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P2.3" name="Receive Shipment">
      <ns0:extensionElements>
        <ns1:actor>Pharmacy Technician</ns1:actor>
        <ns1:durationMin>30 min</ns1:durationMin>
        <ns1:description>Receive delivery from supplier, verify package integrity, check delivery documentation against purchase order.</ns1:description>
        <ns1:inputs>["Delivery", "Purchase order", "Packing slip"]</ns1:inputs>
        <ns1:outputs>["Received goods"]</ns1:outputs>
        <ns1:risks>["Damaged goods", "Wrong delivery", "Temperature excursion"]</ns1:risks>
        <ns1:automationPotential>medium</ns1:automationPotential>
        <ns1:automationNotes>Barcode/RFID scanning at receiving dock</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P2.4" name="Verify Shipment">
      <ns0:extensionElements>
        <ns1:actor>Pharmacist / QA</ns1:actor>
        <ns1:durationMin>20 min</ns1:durationMin>
        <ns1:description>Quality assurance check: verify quantities, lot numbers, expiry dates, and product condition against order details.</ns1:description>
        <ns1:inputs>["Received goods", "Purchase order"]</ns1:inputs>
        <ns1:outputs>["Verified inventory ready for storage"]</ns1:outputs>
        <ns1:risks>["Expired products accepted", "Counterfeit drugs", "Quantity mismatch"]</ns1:risks>
        <ns1:automationPotential>high</ns1:automationPotential>
        <ns1:automationNotes>Automated lot/expiry scanning, serialization verification</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P3.1" name="Classify and Shelve">
      <ns0:extensionElements>
        <ns1:actor>Pharmacy Technician</ns1:actor>
        <ns1:durationMin>15–30 min per batch</ns1:durationMin>
        <ns1:description>Classify medications by category (therapeutic class, controlled substance schedule, temperature requirements) and place on appropriate shelves or in refrigerators/safes.</ns1:description>
        <ns1:inputs>["Verified inventory"]</ns1:inputs>
        <ns1:outputs>["Stored medications"]</ns1:outputs>
        <ns1:risks>["Misplacement", "Wrong storage conditions", "FIFO violation"]</ns1:risks>
        <ns1:automationPotential>high</ns1:automationPotential>
        <ns1:automationNotes>Automated dispensing cabinets (ADCs), carousel systems, pharmacy robots</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P3.2" name="Monitor Storage Conditions">
      <ns0:extensionElements>
        <ns1:actor>Pharmacy Technician / System</ns1:actor>
        <ns1:durationMin>continuous</ns1:durationMin>
        <ns1:description>Monitor temperature, humidity, and security for storage areas. Log conditions for compliance.</ns1:description>
        <ns1:inputs>["Environmental sensors", "Regulatory requirements"]</ns1:inputs>
        <ns1:outputs>["Compliance logs", "Alerts on excursion"]</ns1:outputs>
        <ns1:risks>["Temperature excursion undetected", "Controlled substance diversion"]</ns1:risks>
        <ns1:automationPotential>high</ns1:automationPotential>
        <ns1:automationNotes>IoT sensors, automated alerting, continuous logging systems</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P3.3" name="Inventory Management">
      <ns0:extensionElements>
        <ns1:actor>Pharmacist / System</ns1:actor>
        <ns1:durationMin>daily cycle counts + periodic full inventory</ns1:durationMin>
        <ns1:description>Track stock levels, manage expiry dates (FEFO), conduct cycle counts, and trigger reorder points.</ns1:description>
        <ns1:inputs>["Current stock data", "Usage history", "Expiry dates"]</ns1:inputs>
        <ns1:outputs>["Reorder triggers", "Expiry removal list", "Inventory report"]</ns1:outputs>
        <ns1:risks>["Stockout", "Expired stock dispensed", "Overstock / waste"]</ns1:risks>
        <ns1:automationPotential>high</ns1:automationPotential>
        <ns1:automationNotes>ERP/WMS integration, perpetual inventory systems, AI-based demand forecasting</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P4.1" name="Prepare Distribution">
      <ns0:extensionElements>
        <ns1:actor>Pharmacy Technician</ns1:actor>
        <ns1:durationMin>20–45 min per round</ns1:durationMin>
        <ns1:description>Pick medications for ward/unit orders or patient-specific prescriptions. Build medication carts or fill ADC cassettes.</ns1:description>
        <ns1:inputs>["Ward orders", "Patient prescriptions", "Stock picks"]</ns1:inputs>
        <ns1:outputs>["Prepared medication cart / ADC cassettes"]</ns1:outputs>
        <ns1:risks>["Pick error", "Wrong patient allocation", "Incomplete cart"]</ns1:risks>
        <ns1:automationPotential>high</ns1:automationPotential>
        <ns1:automationNotes>Pharmacy robots, pick-to-light, automated cart fill</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P4.2" name="Transport to Care Unit">
      <ns0:extensionElements>
        <ns1:actor>Porter / Pneumatic tube / AGV</ns1:actor>
        <ns1:durationMin>10–30 min</ns1:durationMin>
        <ns1:description>Transport prepared medications from pharmacy to ward/unit. Methods: manual delivery, pneumatic tube systems, or automated guided vehicles.</ns1:description>
        <ns1:inputs>["Prepared cart / packages"]</ns1:inputs>
        <ns1:outputs>["Medications at care unit"]</ns1:outputs>
        <ns1:risks>["Delay", "Damage in transit", "Temperature excursion for cold chain"]</ns1:risks>
        <ns1:automationPotential>medium</ns1:automationPotential>
        <ns1:automationNotes>AGVs, pneumatic tubes, delivery tracking systems</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P4.3" name="Stock Care Unit">
      <ns0:extensionElements>
        <ns1:actor>Nurse / Pharmacy Technician</ns1:actor>
        <ns1:durationMin>15–20 min</ns1:durationMin>
        <ns1:description>Receive medications at ward, verify against order, and load into ward storage or ADC.</ns1:description>
        <ns1:inputs>["Medications at care unit", "Ward order"]</ns1:inputs>
        <ns1:outputs>["Ward stock ready for administration"]</ns1:outputs>
        <ns1:risks>["Wrong ward", "Receiving error", "ADC load error"]</ns1:risks>
        <ns1:automationPotential>medium</ns1:automationPotential>
        <ns1:automationNotes>ADC with barcode verification, nurse confirmation scan</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P5.1" name="Compound / Prepare">
      <ns0:extensionElements>
        <ns1:actor>Pharmacist / Pharmacy Technician</ns1:actor>
        <ns1:durationMin>5–60 min (varies by complexity)</ns1:durationMin>
        <ns1:description>For non-standard preparations: compound medication (e.g. IV admixtures, pediatric formulations, sterile compounds). For standard items: count/pour and label.</ns1:description>
        <ns1:inputs>["Approved prescription", "Raw materials or stock"]</ns1:inputs>
        <ns1:outputs>["Prepared medication with label"]</ns1:outputs>
        <ns1:risks>["Compounding error", "Contamination", "Wrong concentration"]</ns1:risks>
        <ns1:automationPotential>medium</ns1:automationPotential>
        <ns1:automationNotes>IV workflow management, gravimetric verification, compounding robots</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P5.2" name="Final Verification">
      <ns0:extensionElements>
        <ns1:actor>Pharmacist</ns1:actor>
        <ns1:durationMin>3–5 min</ns1:durationMin>
        <ns1:description>Independent check of dispensed medication against prescription: right drug, right dose, right form, right label, right patient.</ns1:description>
        <ns1:inputs>["Prepared medication", "Original prescription"]</ns1:inputs>
        <ns1:outputs>["Verified medication ready for patient"]</ns1:outputs>
        <ns1:risks>["Verification shortcut under pressure", "Look-alike/sound-alike error"]</ns1:risks>
        <ns1:automationPotential>high</ns1:automationPotential>
        <ns1:automationNotes>Barcode verification, image recognition, automated dispensing check</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P5.3" name="Patient Counseling">
      <ns0:extensionElements>
        <ns1:actor>Pharmacist</ns1:actor>
        <ns1:durationMin>3–10 min</ns1:durationMin>
        <ns1:description>Explain medication use, dosage, side effects, interactions, and storage instructions to patient or caregiver.</ns1:description>
        <ns1:inputs>["Verified medication", "Patient profile"]</ns1:inputs>
        <ns1:outputs>["Informed patient", "Counseling record"]</ns1:outputs>
        <ns1:risks>["Missed counseling", "Patient misunderstanding", "Language barrier"]</ns1:risks>
        <ns1:automationPotential>low</ns1:automationPotential>
        <ns1:automationNotes>Printed/digital information sheets, automated reminders for new medications</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P6.1" name="Prepare for Administration">
      <ns0:extensionElements>
        <ns1:actor>Nurse</ns1:actor>
        <ns1:durationMin>3–5 min</ns1:durationMin>
        <ns1:description>Retrieve medication from ward stock or ADC. Verify the '5 Rights': right patient, right drug, right dose, right route, right time.</ns1:description>
        <ns1:inputs>["Ward stock", "MAR (Medication Administration Record)", "Patient ID"]</ns1:inputs>
        <ns1:outputs>["Medication ready for administration"]</ns1:outputs>
        <ns1:risks>["Wrong patient", "Wrong time", "Omission"]</ns1:risks>
        <ns1:automationPotential>high</ns1:automationPotential>
        <ns1:automationNotes>Bedside barcode scanning, eMAR integration, smart pumps</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P6.2" name="Administer to Patient">
      <ns0:extensionElements>
        <ns1:actor>Nurse / Physician</ns1:actor>
        <ns1:durationMin>2–10 min</ns1:durationMin>
        <ns1:description>Give medication to patient via prescribed route (oral, IV, IM, topical, etc.). Monitor for immediate adverse reactions.</ns1:description>
        <ns1:inputs>["Prepared medication", "Patient"]</ns1:inputs>
        <ns1:outputs>["Administered medication"]</ns1:outputs>
        <ns1:risks>["Wrong route", "Adverse reaction", "Extravasation (IV)"]</ns1:risks>
        <ns1:automationPotential>low</ns1:automationPotential>
        <ns1:automationNotes>Smart IV pumps with dose-error reduction, automated documentation</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P6.3" name="Document Administration">
      <ns0:extensionElements>
        <ns1:actor>Nurse</ns1:actor>
        <ns1:durationMin>2–3 min</ns1:durationMin>
        <ns1:description>Record administration in patient's MAR: drug, dose, time, route, administering nurse. Note any patient reactions.</ns1:description>
        <ns1:inputs>["Administration details"]</ns1:inputs>
        <ns1:outputs>["Updated MAR", "Incident report (if adverse event)"]</ns1:outputs>
        <ns1:risks>["Late documentation", "Missing record", "Inaccurate entry"]</ns1:risks>
        <ns1:automationPotential>high</ns1:automationPotential>
        <ns1:automationNotes>Auto-populated eMAR from barcode scan, voice-to-text notes</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P7.1" name="Monitor Patient Response">
      <ns0:extensionElements>
        <ns1:actor>Nurse / Physician</ns1:actor>
        <ns1:durationMin>ongoing</ns1:durationMin>
        <ns1:description>Observe and document patient response to medication. Assess efficacy and side effects. Adjust treatment as needed.</ns1:description>
        <ns1:inputs>["Patient vitals", "Lab results", "Patient feedback"]</ns1:inputs>
        <ns1:outputs>["Treatment efficacy assessment", "Dosage adjustment order"]</ns1:outputs>
        <ns1:risks>["Delayed detection of adverse effect", "Non-adherence"]</ns1:risks>
        <ns1:automationPotential>medium</ns1:automationPotential>
        <ns1:automationNotes>Clinical decision support alerts, remote monitoring, AI-based adverse event detection</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P7.2" name="Handle Returns and Expired Stock">
      <ns0:extensionElements>
        <ns1:actor>Pharmacy Technician</ns1:actor>
        <ns1:durationMin>varies</ns1:durationMin>
        <ns1:description>Collect unused or expired medications from wards and patients. Segregate for destruction or return to supplier.</ns1:description>
        <ns1:inputs>["Expired stock list", "Ward returns"]</ns1:inputs>
        <ns1:outputs>["Destruction records", "Credit notes from supplier"]</ns1:outputs>
        <ns1:risks>["Expired drugs re-entering stock", "Controlled substance diversion"]</ns1:risks>
        <ns1:automationPotential>medium</ns1:automationPotential>
        <ns1:automationNotes>FEFO alerts, automated expiry tracking, secure destruction logging</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:task id="P7.3" name="Regulatory Reporting">
      <ns0:extensionElements>
        <ns1:actor>Pharmacist / QA</ns1:actor>
        <ns1:durationMin>periodic</ns1:durationMin>
        <ns1:description>Compile and submit required reports: controlled substance logs, adverse event reports, cold chain compliance, inventory audits.</ns1:description>
        <ns1:inputs>["Logs", "Incident reports", "Audit data"]</ns1:inputs>
        <ns1:outputs>["Regulatory submissions", "Compliance certificates"]</ns1:outputs>
        <ns1:risks>["Non-compliance", "Missing data", "Late submission"]</ns1:risks>
        <ns1:automationPotential>high</ns1:automationPotential>
        <ns1:automationNotes>Automated report generation, dashboard-based compliance monitoring</ns1:automationNotes>
      </ns0:extensionElements>
    </ns0:task>
    <ns0:sequenceFlow id="flow_Start_P1.1" sourceRef="Start_1" targetRef="P1.1" name="Process starts" />
    <ns0:sequenceFlow id="flow_P1.1_P1.2_0" sourceRef="P1.1" targetRef="P1.2" name="Prescription submitted" />
    <ns0:sequenceFlow id="flow_P1.2_P1.3_1" sourceRef="P1.2" targetRef="P1.3" name="Prescription verified" />
    <ns0:sequenceFlow id="flow_P1.3_P2.1_2" sourceRef="P1.3" targetRef="P2.1" name="Prescription approved" />
    <ns0:sequenceFlow id="flow_P2.1_G2" sourceRef="P2.1" targetRef="G2" name="" />
    <ns0:sequenceFlow id="flow_G2_P5.1" sourceRef="G2" targetRef="P5.1" name="In stock">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">In stock</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="flow_G2_P2.2" sourceRef="G2" targetRef="P2.2" name="Out of stock">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">Out of stock</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="flow_P2.2_P2.3_5" sourceRef="P2.2" targetRef="P2.3" name="Shipment arrives" />
    <ns0:sequenceFlow id="flow_P2.3_P2.4_6" sourceRef="P2.3" targetRef="P2.4" name="Shipment received" />
    <ns0:sequenceFlow id="flow_P2.4_P3.1_7" sourceRef="P2.4" targetRef="P3.1" name="Verified, ready to store" />
    <ns0:sequenceFlow id="flow_P3.1_P3.2_8a" sourceRef="P3.1" targetRef="P3.2" name="Stored, monitor conditions" />
    <ns0:sequenceFlow id="flow_P3.2_P3.3_8b" sourceRef="P3.2" targetRef="P3.3" name="Conditions OK, track inventory" />
    <ns0:sequenceFlow id="flow_P3.3_G3" sourceRef="P3.3" targetRef="G3" name="" />
    <ns0:sequenceFlow id="flow_G3_P2.1" sourceRef="G3" targetRef="P2.1" name="Stock available for selection">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">Item in stock</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="flow_G3_P2.2" sourceRef="G3" targetRef="P2.2" name="Trigger reorder">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">Below reorder point</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="flow_G3_P4.1" sourceRef="G3" targetRef="P4.1" name="Pick for distribution">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">Ward order received</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="flow_G3_P7.2" sourceRef="G3" targetRef="P7.2" name="Remove expired">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">Expired stock detected</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="flow_P4.1_P4.2_11" sourceRef="P4.1" targetRef="P4.2" name="Cart prepared" />
    <ns0:sequenceFlow id="flow_P4.2_P4.3_12" sourceRef="P4.2" targetRef="P4.3" name="Delivered to unit" />
    <ns0:sequenceFlow id="flow_P5.1_P5.2_13" sourceRef="P5.1" targetRef="P5.2" name="Preparation done" />
    <ns0:sequenceFlow id="flow_P5.2_G5" sourceRef="P5.2" targetRef="G5" name="" />
    <ns0:sequenceFlow id="flow_G5_P5.3" sourceRef="G5" targetRef="P5.3" name="Outpatient">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">Outpatient</ns0:conditionExpression>
    </ns0:sequenceFlow>
