# Get your key at https://console.groq.com — then copy this file to .env and set it.
GROQ_KEY=your_groq_api_key_here

# Optional: path to baseline BPMN file (default: backend/data/pharmacy_circuit.bpmn)
# BASELINE_GRAPH_PATH=data/pharmacy_circuit.bpmn

# Agent: max tool-call rounds per chat turn (default: 10)
# MAX_TOOL_ROUNDS=10
# Groq API timeout in seconds (default: 60)
# GROQ_TIMEOUT=60
# Groq API retries on failure (default: 2)
# GROQ_MAX_RETRIES=2

# CORS: comma-separated allowed origins (default: localhost Vite dev)
# ALLOWED_CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Storage: "memory" (default) or "file"
# STORAGE=memory
# When STORAGE=file, directory for session JSON files (default: backend/data/sessions)
# SESSION_DATA_DIR=data/sessions
