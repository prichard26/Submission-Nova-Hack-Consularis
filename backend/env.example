# ── AWS Bedrock — active by default ──
# Get these from the AWS Console → IAM → Security Credentials (or create an IAM user).
# The user/role needs the bedrock:InvokeModel permission.
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
# Default planner model (used when user has not picked one, or as fallback).
NOVA_MODEL_ID=us.amazon.nova-pro-v1:0
# Optional: cheaper model for executor retries. If unset, NOVA_MODEL_ID is used.
# NOVA_CHEAP_MODEL_ID=us.amazon.nova-2-lite-v1:0

# Optional: full list of models for the chat model picker. If unset, a built-in US list is used.
# Single line, JSON array. Each item: id, label, family (nova|claude|llama|mistral), tier (pro|lite), description.
# BEDROCK_MODELS_JSON=[{"id":"eu.amazon.nova-pro-v1:0","label":"Nova Pro (EU)","family":"nova","tier":"pro","description":"Default"},{"id":"eu.amazon.nova-2-lite-v1:0","label":"Nova 2 Lite (EU)","family":"nova","tier":"lite","description":"Cheaper"}]

# Optional: template used to seed baseline at startup (default: pharmacy). One subfolder per type under data/: pharmacy/, logistics/, manufacturing/
# BASELINE_TEMPLATE=pharmacy

# Optional: default process ID for API requests (default: Process_Global)
# DEFAULT_PROCESS_ID=Process_Global

# Agent: max tool-call rounds per chat turn (default: 10)
# MAX_TOOL_ROUNDS=10
# Bedrock timeout in seconds (default: 120)
# BEDROCK_TIMEOUT=120
# Context: keep this many recent chat messages verbatim; older ones are summarized (default: 20)
# MAX_RECENT_MESSAGES=20
# Max tokens for the rolling conversation summary (default: 512)
# SUMMARY_MODEL_MAX_TOKENS=512
# CORS: comma-separated allowed origins (default: localhost Vite dev)
# ALLOWED_CORS_ORIGINS=http://localhost:5173,http://localhost:5174
# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO
